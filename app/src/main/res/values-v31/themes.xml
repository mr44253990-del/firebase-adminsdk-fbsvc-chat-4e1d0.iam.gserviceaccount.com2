<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system launch window: transparent icon prevents the launcher badge flash.
         The Compose Liquid Glass splash is rendered immediately afterwards. -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowSplashScreenBackground">#17132F</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#17132F</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
</resources>
