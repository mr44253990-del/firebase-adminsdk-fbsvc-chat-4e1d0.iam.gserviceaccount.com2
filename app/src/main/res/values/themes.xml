<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:colorAccent">#8A72FF</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#17132F</item>
        <item name="android:navigationBarColor">#17132F</item>
        <item name="android:windowDisablePreview">false</item>
    </style>

    <style name="Theme.MyApplication.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#17132F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">100</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>
</resources>
